# Database (used by backend and import script)
# When running in Docker Compose, use hostname "db" and port 5432.
# When running backend/import on host, use localhost:5432.
DATABASE_URL=postgresql://ais_user:ais_pass@localhost:5432/ais

# Optional: Next.js API proxy target (default if unset)
# NEXT_PUBLIC_API_URL=http://localhost:8000

# AISStream.io (recommended): WebSocket live AIS for California coast. Get key at https://aisstream.io/
AISSTREAM_API_KEY=your_api_key

# Optional: AISHub (HTTP, California coast) – username from https://www.aishub.net/
# AISHUB_USERNAME=your_username

# Optional: generic AIS API URL (for --source URL or AIS_API_URL)
# AIS_API_URL=https://example.com/ais/positions
# AIS_API_KEY=optional_bearer_token
