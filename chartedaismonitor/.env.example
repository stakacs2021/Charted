# --- Postgres (must match across db container, backend, ingest, and host tools) ---
POSTGRES_PASSWORD=changeme
# For pg_dump / pytest / scripts on the HOST (Postgres is published on 127.0.0.1:5432 only)
DATABASE_URL=postgresql://ais_user:changeme@127.0.0.1:5432/ais

# --- Browser → API (set before building the frontend image) ---
# Replace YOUR_LAN_IP with this machine's IPv4 (e.g. 192.168.1.50). Same machine: http://127.0.0.1:8000
NEXT_PUBLIC_API_URL=http://YOUR_LAN_IP:8000

# --- AIS live ingest (AISStream WebSocket). Required for the `ingest` Compose profile. ---
AISSTREAM_API_KEY=your_api_key

# Optional: publish backend/frontend on loopback only (host Nginx reverse proxy — see SELF_HOST.md)
# BACKEND_HOST=127.0.0.1
# BACKEND_PORT=8000
# FRONTEND_HOST=127.0.0.1
# FRONTEND_PORT=3000

# Optional: enable AISStream ingest service with `docker compose up` (see SELF_HOST.md)
# COMPOSE_PROFILES=ais

# Optional: AISHub (HTTP, California coast) – username from https://www.aishub.net/
# AISHUB_USERNAME=your_username

# Optional: generic AIS API URL (for --source URL or AIS_API_URL)
# AIS_API_URL=https://example.com/ais/positions
# AIS_API_KEY=optional_bearer_token

# --- MPA violation suppression heuristics (Layer 1) ---
# Speed-over-ground above this many knots is treated as transit (no violation).
# MPA_SPEED_TRANSIT_KN=5.0
# Vessel must remain inside a zone this many seconds before a violation fires.
# Set to 0 to record on the first inside fix (no debounce).
# MPA_MIN_DWELL_SECONDS=120
# Skip recording if a position is within this many meters of the zone boundary
# (suppresses GPS-jitter / boundary-clipping false positives). Set 0 to disable.
# MPA_BOUNDARY_BUFFER_M=30
