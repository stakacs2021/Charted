[Unit]
Description=Charted AIS MPA Monitor (Docker Compose)
After=docker.service network-online.target
Requires=docker.service
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/ABSOLUTE/PATH/TO/chartedaismonitor
# Adjust if docker compose lives elsewhere:
ExecStart=/usr/bin/docker compose up -d
ExecStop=/usr/bin/docker compose stop
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target
